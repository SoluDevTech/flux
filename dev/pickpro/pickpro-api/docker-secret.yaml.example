apiVersion: v1
kind: Secret
metadata:
  name: pickpro-docker-secret
  namespace: pickpro
type: kubernetes.io/dockerconfigjson
stringData:
  # Remplacer par le vrai dockerconfigjson (kubectl create secret docker-registry ...)
  .dockerconfigjson: '{"auths":{"https://index.docker.io/v1/":{"username":"REPLACE_ME","password":"REPLACE_ME","email":"REPLACE_ME","auth":"REPLACE_ME"}}}'